<?xml version="1.0" encoding="UTF-8"?>
<configuration debug="false">
	<!-- 日志存储地址 -->
	<property name="LOG_HOME" value="../logs" />

	<!-- ============================================================ -->
	<!-- 控制台输出（带 MDC 设备标签） -->
	<!-- ============================================================ -->
	<appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
		<encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
			<pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %highlight(%-5level) %cyan(%logger{50}:%L) %yellow([%X{deviceSn:-}]) - %msg%n</pattern>
		</encoder>
	</appender>

	<!-- ============================================================ -->
	<!-- 全量业务日志文件（按天滚动，保留 30 天） -->
	<!-- ============================================================ -->
	<appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
		<file>${LOG_HOME}/neuron.log</file>
		<rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
			<FileNamePattern>${LOG_HOME}/neuron-%d{yyyy-MM-dd}.%i.log</FileNamePattern>
			<MaxHistory>30</MaxHistory>
			<maxFileSize>50MB</maxFileSize>
			<totalSizeCap>1GB</totalSizeCap>
		</rollingPolicy>
		<encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
			<pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50}:%L [%X{deviceSn:-}] - %msg%n</pattern>
		</encoder>
	</appender>

	<!-- ============================================================ -->
	<!-- OCPP 设备通信专用日志（排查设备问题用） -->
	<!-- ============================================================ -->
	<appender name="OCPP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
		<file>${LOG_HOME}/neuron-ocpp.log</file>
		<rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
			<FileNamePattern>${LOG_HOME}/neuron-ocpp-%d{yyyy-MM-dd}.%i.log</FileNamePattern>
			<MaxHistory>30</MaxHistory>
			<maxFileSize>50MB</maxFileSize>
			<totalSizeCap>1GB</totalSizeCap>
		</rollingPolicy>
		<encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
			<pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{deviceSn:-}] - %msg%n</pattern>
		</encoder>
	</appender>

	<!-- ============================================================ -->
	<!-- ERROR 日志单独文件（快速定位异常） -->
	<!-- ============================================================ -->
	<appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
		<file>${LOG_HOME}/neuron-error.log</file>
		<filter class="ch.qos.logback.classic.filter.ThresholdFilter">
			<level>ERROR</level>
		</filter>
		<rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
			<FileNamePattern>${LOG_HOME}/neuron-error-%d{yyyy-MM-dd}.%i.log</FileNamePattern>
			<MaxHistory>30</MaxHistory>
			<maxFileSize>10MB</maxFileSize>
		</rollingPolicy>
		<encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
			<pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50}:%L [%X{deviceSn:-}] - %msg%n</pattern>
		</encoder>
	</appender>

	<!-- ============================================================ -->
	<!-- Logger 配置 -->
	<!-- ============================================================ -->

	<!-- OCPP 协议层：输出到 OCPP 专用日志文件 -->
	<logger name="com.echarge.protocol" level="INFO" additivity="true">
		<appender-ref ref="OCPP_FILE" />
	</logger>

	<!-- 设备事件处理：也输出到 OCPP 日志文件 -->
	<logger name="com.echarge.modules.device.listener" level="INFO" additivity="true">
		<appender-ref ref="OCPP_FILE" />
	</logger>

	<!-- 告警事件处理：也输出到 OCPP 日志文件 -->
	<logger name="com.echarge.modules.alert.listener" level="INFO" additivity="true">
		<appender-ref ref="OCPP_FILE" />
	</logger>

	<!-- MyBatis SQL（生产环境建议改为 INFO 或 WARN） -->
	<logger name="com.apache.ibatis" level="TRACE" />
	<logger name="java.sql.Connection" level="DEBUG" />
	<logger name="java.sql.Statement" level="DEBUG" />
	<logger name="java.sql.PreparedStatement" level="DEBUG" />

	<!-- 根日志级别 -->
	<root level="INFO">
		<appender-ref ref="STDOUT" />
		<appender-ref ref="FILE" />
		<appender-ref ref="ERROR_FILE" />
	</root>

</configuration>
